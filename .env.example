# Public site configuration
NEXT_PUBLIC_SITE_URL=https://danawangsa-capital.vercel.app

# Consultation form webhook (required for form submission)
# Examples:
#   Formspree: https://formspree.io/f/xxxxxxxx
#   n8n:       https://your-n8n.app/webhook/consultation
#   Make/Zapier/custom API endpoint
CONSULTATION_WEBHOOK_URL=

# Gemini API (required for IDA chatbot)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Analytics 4 (optional — page views & conversion events)
# Format: G-XXXXXXXXXX (from GA4 Admin → Data Streams → Web)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional future integrations
# RESEND_API_KEY=
# DATABASE_URL=